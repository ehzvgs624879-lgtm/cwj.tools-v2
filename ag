#!/bin/bash
PROJECT_DIR="/data/data/com.termux/files/home/cwj.tools-v2"
CONFIG="$PROJECT_DIR/config.json"

# 如果传入了模型名，先切换
if [ -n "$1" ]; then
    python3 -c "
import json, sys
cfg = json.load(open('$CONFIG'))
name = '$1'
if name not in cfg.get('profiles', {}):
    print(f'❌ 模型 {name} 不存在，可用模型：')
    for k in cfg['profiles']:
        print(f'  - {k}')
    sys.exit(1)
cfg['active_profile'] = name
json.dump(cfg, open('$CONFIG','w'), indent=2, ensure_ascii=False)
print(f'✅ 已切换至模型 {name}')
" || exit 1
fi

cd "$PROJECT_DIR" && python3 search_agent.py
