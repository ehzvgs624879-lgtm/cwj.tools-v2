#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
掌上全自动 Groq Agent (纯本地工具版)
────────────────────────────────────
✅ 危险命令拦截
✅ 操作前确认（可跳过）
✅ 工作目录限制
✅ 命令超时
✅ 输出自动裁剪
✅ 对话上下文管理
✅ 工具集：命令执行、文件读写、代码搜索、目录列表、包安装
✅ 思维链提示
✅ 流式输出汇报
✅ 彩色日志
✅ 对话历史 Markdown 保存
✅ 环境自检
"""

import os
import json
import subprocess
import datetime
from openai import OpenAI

# ─── 配置常量 ──────────────────────────
API_KEY = os.environ.get("GROQ_API_KEY")
BASE_URL = "https://api.groq.com/openai/v1"
MODEL_NAME = "llama-3.3-70b-versatile"

WORKSPACE = os.path.expanduser("~/agent_workspace")
MAX_OUTPUT_LEN = 2000
COMMAND_TIMEOUT = 30
MAX_MESSAGES = 20
AUTO_CONFIRM = os.environ.get("AUTO_CONFIRM") == "1"

DANGEROUS_PATTERNS = [
    "rm -rf /",
    "mkfs.",
    "dd if=",
    "> /dev/",
    ":(){ :|:& }:",
    "chmod 777 /",
    "shutdown",
    "reboot"
]

# ─── 颜色支持 ──────────────────────────
class Colors:
    BOLD = '\033[1m'
    RED = '\033[91m'
    GREEN = '\033[92m'
    YELLOW = '\033[93m'
    BLUE = '\033[94m'
    CYAN = '\033[96m'
    RESET = '\033[0m'

def color_print(text, color=Colors.RESET, bold=False):
    prefix = Colors.BOLD if bold else ""
    print(f"{prefix}{color}{text}{Colors.RESET}")

# ─── 环境自检 ──────────────────────────
def check_environment():
    print(f"\n{Colors.CYAN}🔍 环境自检中...{Colors.RESET}")
    deps = {
        "python3": "python3 --version",
        "git": "git --version",
        "curl": "curl --version",
        "pkg": "pkg --version",
        "grep": "grep --version"
    }
    all_ok = True
    for name, cmd in deps.items():
        try:
            subprocess.run(cmd, shell=True, capture_output=True, timeout=5, check=True)
            print(f"  ✅ {name}")
        except Exception:
            print(f"  ❌ {name} 未找到，部分功能可能不可用")
            all_ok = False
    if all_ok:
        color_print("✨ 环境检查通过！", Colors.GREEN)
    else:
        color_print("⚠️ 部分工具缺失，可以运行 pkg install xxx 安装", Colors.YELLOW)
    print()

# ─── 初始化客户端 ───────────────────────
if not API_KEY:
    color_print("❌ 错误: 没找到你的 API Key! 请先运行 'export GROQ_API_KEY=你的Key'", Colors.RED)
    exit(1)

client = OpenAI(api_key=API_KEY, base_url=BASE_URL)
os.makedirs(WORKSPACE, exist_ok=True)

# ─── 工具函数 ──────────────────────────
def safe_truncate(text):
    if len(text) <= MAX_OUTPUT_LEN:
        return text
    return text[:MAX_OUTPUT_LEN] + "\n... [输出已截断]"

def run_command(command):
    for pattern in DANGEROUS_PATTERNS:
        if pattern in command.lower():
            return f"⛔ 危险命令已拦截: 包含 '{pattern}'"
    print(f"{Colors.BLUE}⚙️ [执行命令]:{Colors.RESET} {command}")
    try:
        result = subprocess.run(
            command, shell=True, capture_output=True, text=True, timeout=COMMAND_TIMEOUT
        )
        output = (result.stdout + result.stderr).strip()
        return output if output else "(命令执行成功，无输出)"
    except subprocess.TimeoutExpired:
        return f"⏰ 命令超时（{COMMAND_TIMEOUT}秒），已自动终止"
    except Exception as e:
        return f"❌ 命令执行出错: {str(e)}"

def _check_path(filepath):
    full = os.path.abspath(os.path.join(WORKSPACE, filepath))
    if not full.startswith(os.path.abspath(WORKSPACE)):
        return None
    return full

def read_file(filepath):
    full = _check_path(filepath)
    if not full:
        return "⛔ 只允许读取工作区内的文件"
    print(f"{Colors.GREEN}📖 [读取文件]:{Colors.RESET} {filepath}")
    try:
        with open(full, 'r') as f:
            return safe_truncate(f.read())
    except Exception as e:
        return f"读取失败: {e}"

def write_file(filepath, content):
    full = _check_path(filepath)
    if not full:
        return "⛔ 只允许写入工作区内的文件"
    print(f"{Colors.YELLOW}✍️ [修改文件]:{Colors.RESET} {filepath}")
    try:
        os.makedirs(os.path.dirname(full), exist_ok=True)
        with open(full, 'w') as f:
            f.write(content)
        return f"成功写入 {filepath}"
    except Exception as e:
        return f"写入失败: {e}"

def search_code(query, path="."):
    full = _check_path(path)
    if not full:
        return "⛔ 搜索路径必须在工作区内"
    print(f"{Colors.CYAN}🔎 [搜索代码]:{Colors.RESET} '{query}' in {path}")
    try:
        result = subprocess.run(
            f"grep -rn '{query}' {full}",
            shell=True, capture_output=True, text=True, timeout=10
        )
        return safe_truncate(result.stdout) or "未找到匹配内容"
    except subprocess.TimeoutExpired:
        return "⏰ 搜索超时"
    except Exception as e:
        return f"搜索出错: {e}"

def list_dir(path="."):
    full = _check_path(path)
    if not full:
        return "⛔ 只能列出工作区内的目录"
    print(f"{Colors.CYAN}📂 [列出目录]:{Colors.RESET} {path}")
    try:
        items = os.listdir(full)
        if not items:
            return "(空目录)"
        result = []
        for item in sorted(items):
            item_path = os.path.join(full, item)
            flag = "/" if os.path.isdir(item_path) else ""
            result.append(f"  {item}{flag}")
        return "\n".join(result)
    except Exception as e:
        return f"列出目录失败: {e}"

def install_pkg(pkg_name):
    print(f"{Colors.YELLOW}📦 [安装包]:{Colors.RESET} {pkg_name}")
    try:
        result = subprocess.run(
            f"pkg install -y {pkg_name}",
            shell=True, capture_output=True, text=True, timeout=60
        )
        output = result.stdout[-MAX_OUTPUT_LEN:]
        return output if output else "安装完成"
    except subprocess.TimeoutExpired:
        return "⏰ 安装超时"
    except Exception as e:
        return f"安装出错: {e}"

# ─── 工具定义（已移除联网搜索） ──────────
tools = [
    {
        "type": "function",
        "function": {
            "name": "run_command",
            "description": "在终端执行 Linux 命令（危险命令会被拦截）",
            "parameters": {
                "type": "object",
                "properties": {"command": {"type": "string"}},
                "required": ["command"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "read_file",
            "description": "读取工作区内的文件内容",
            "parameters": {
                "type": "object",
                "properties": {"filepath": {"type": "string"}},
                "required": ["filepath"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "write_file",
            "description": "写入或覆盖工作区内的文件",
            "parameters": {
                "type": "object",
                "properties": {
                    "filepath": {"type": "string"},
                    "content": {"type": "string"}
                },
                "required": ["filepath", "content"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "search_code",
            "description": "在工作区代码中搜索关键词（grep）",
            "parameters": {
                "type": "object",
                "properties": {
                    "query": {"type": "string"},
                    "path": {"type": "string", "default": "."}
                },
                "required": ["query"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "list_dir",
            "description": "列出工作区内目录结构",
            "parameters": {
                "type": "object",
                "properties": {"path": {"type": "string", "default": "."}},
                "required": []
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "install_pkg",
            "description": "在 Termux 中安装软件包",
            "parameters": {
                "type": "object",
                "properties": {"pkg_name": {"type": "string"}},
                "required": ["pkg_name"]
            }
        }
    }
]

# ─── 系统提示词（已移除联网相关描述） ───
SYSTEM_PROMPT = (
    "你是一个运行在 Android Termux 里的全自动资深程序员 Agent。"
    "你的操作均被限制在工作目录 ~/agent_workspace 内，可以安全地读写文件、执行命令。"
    "接到任务后，请先在内心规划步骤，然后按需调用工具逐步实施。"
    "所有操作完成后，用中文清晰汇报你做了什么、结果如何。"
    "如果操作失败，请说明原因并给出解决建议。"
)

# ─── 对话日志 ──────────────────────────
def save_log(messages, last_user, last_assistant):
    log_file = "agent_history.md"
    with open(log_file, "a", encoding="utf-8") as f:
        timestamp = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        f.write(f"\n---\n### {timestamp}\n")
        f.write(f"**👤 老板:** {last_user}\n\n")
        f.write(f"**🤖 Agent:** {last_assistant}\n\n")

# ─── 主循环 ────────────────────────────
def main():
    check_environment()
    messages = [{"role": "system", "content": SYSTEM_PROMPT}]
    print(f"{Colors.BOLD}🚀 掌上全自动 Groq Agent (纯本地版) 已启动！{Colors.RESET}")
    print(f"工作区: {WORKSPACE}")
    print("输入 'quit' 退出，输入 'clear' 重置对话\n")

    while True:
        try:
            user_input = input(f"{Colors.BOLD}👤 老板请吩咐:{Colors.RESET} ")
        except (EOFError, KeyboardInterrupt):
            print("\n👋 再见！")
            break

        if user_input.lower() in ['quit', 'exit']:
            break
        if user_input.lower() == 'clear':
            messages = [{"role": "system", "content": SYSTEM_PROMPT}]
            color_print("♻️ 对话已重置", Colors.CYAN)
            continue

        messages.append({"role": "user", "content": user_input})

        try:
            response = client.chat.completions.create(
                model=MODEL_NAME,
                messages=messages,
                tools=tools
            )
        except Exception as e:
            color_print(f"❌ API 调用失败: {e}", Colors.RED)
            continue

        msg = response.choices[0].message
        messages.append(msg)

        if msg.tool_calls:
            color_print("\n🔧 Agent 计划执行以下操作：", Colors.BOLD)
            for i, tool in enumerate(msg.tool_calls, 1):
                args = json.loads(tool.function.arguments)
                color_print(f"  {i}. {tool.function.name}: {args}", Colors.CYAN)

            if not AUTO_CONFIRM:
                confirm = input(f"{Colors.YELLOW}是否执行? (y/n，直接回车=是):{Colors.RESET} ")
                if confirm.lower() == 'n':
                    for tool in msg.tool_calls:
                        messages.append({
                            "role": "tool",
                            "tool_call_id": tool.id,
                            "content": "用户取消了操作"
                        })
                    color_print("⏸️ 已取消操作", Colors.YELLOW)
                    resp2 = client.chat.completions.create(model=MODEL_NAME, messages=messages)
                    final_msg = resp2.choices[0].message.content
                    print(f"{Colors.GREEN}🤖 [Agent]:{Colors.RESET} {final_msg}")
                    save_log(messages, user_input, final_msg)
                    continue

            for tool in msg.tool_calls:
                args = json.loads(tool.function.arguments)
                try:
                    if tool.function.name == "run_command":
                        res = run_command(args["command"])
                    elif tool.function.name == "read_file":
                        res = read_file(args["filepath"])
                    elif tool.function.name == "write_file":
                        res = write_file(args["filepath"], args["content"])
                    elif tool.function.name == "search_code":
                        res = search_code(args.get("query", ""), args.get("path", "."))
                    elif tool.function.name == "list_dir":
                        res = list_dir(args.get("path", "."))
                    elif tool.function.name == "install_pkg":
                        res = install_pkg(args["pkg_name"])
                    else:
                        res = f"未知工具: {tool.function.name}"
                except Exception as e:
                    res = f"工具执行异常: {e}"

                messages.append({
                    "role": "tool",
                    "tool_call_id": tool.id,
                    "content": safe_truncate(res)
                })

            color_print(f"\n{Colors.GREEN}🤖 [Agent汇报]:{Colors.RESET}", bold=True)
            try:
                stream = client.chat.completions.create(
                    model=MODEL_NAME,
                    messages=messages,
                    stream=True
                )
                collected = []
                for chunk in stream:
                    if chunk.choices[0].delta.content:
                        text = chunk.choices[0].delta.content
                        print(text, end="", flush=True)
                        collected.append(text)
                print()
                final_answer = "".join(collected)
                messages.append({"role": "assistant", "content": final_answer})
            except Exception as e:
                color_print(f"\n❌ 流式汇报失败: {e}", Colors.RED)
                final_answer = "(汇报生成失败)"
                messages.append({"role": "assistant", "content": final_answer})

            save_log(messages, user_input, final_answer)

        else:
            answer = msg.content or "(模型无输出)"
            print(f"{Colors.GREEN}🤖 [Agent]:{Colors.RESET} {answer}")
            save_log(messages, user_input, answer)

        if len(messages) > MAX_MESSAGES + 1:
            messages = [messages[0]] + messages[-(MAX_MESSAGES):]

if __name__ == "__main__":
    main()
